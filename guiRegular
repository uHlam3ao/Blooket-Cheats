(async () => {
    const getReactState = () => {
        const el = document.querySelector("#app > div > div");
        if (!el) return null;
        for (const key in el) {
            if (key.startsWith("__reactInternalInstance$") || key.startsWith("__reactFiber$")) {
                return el[key]?.return?.stateNode;
            }
        }
        return null;
    };

    const executeStatChange = (key, amount, logOutput) => {
        let stateNode = getReactState();
        if (!stateNode || !stateNode.props || !stateNode.props.firebase) {
            logOutput("Error: Match data not found!", "#ff4757");
            return;
        }
        let props = stateNode.props;
        props.firebase.setVal({
            id: props.client.hostId,
            path: "c/" + props.client.name + "/" + key,
            val: Number(amount)
        });
        logOutput(`Set ${key.toUpperCase()} to ${amount}`, "#2ed573");
    };

    if (document.getElementById('blooket-term')) {
        document.getElementById('blooket-term').remove();
        return;
    }

    const terminal = document.createElement('div');
    terminal.id = 'blooket-term';
    terminal.style = 'position:fixed; bottom:20px; left:20px; z-index:99999; width:460px; height:320px; background:#1c1c1c; border:2px solid #00ff00; border-radius:8px; font-family:monospace; color:#00ff00; padding:12px; box-shadow:0 12px 36px rgba(0,0,0,0.8); display:flex; flex-direction:column; box-sizing:border-box; opacity:0.95;';

    const header = document.createElement('div');
    header.innerHTML = 'Blooket Console [Bookmarklet Edition]<br>Type "help" to view the available commands.<br>--------------------------------------------------';
    header.style = 'font-size:11px; margin-bottom:8px; color:#a4b0be; line-height:1.4;';
    terminal.appendChild(header);

    const outputLog = document.createElement('div');
    outputLog.style = 'flex:1; overflow-y:auto; font-size:13px; margin-bottom:8px; line-height:1.4; white-space:pre-wrap; border-bottom:1px solid #333; padding-bottom:5px;';
    terminal.appendChild(outputLog);

    const inputLine = document.createElement('div');
    inputLine.style = 'display:flex; align-items:center;';
    
    const promptLabel = document.createElement('span');
    promptLabel.innerHTML = 'Blooket:\\User&gt;&nbsp;';
    
    const cmdInput = document.createElement('input');
    cmdInput.type = 'text';
    cmdInput.style = 'flex:1; background:transparent; border:none; color:#00ff00; font-family:monospace; font-size:13px; outline:none;';
    
    inputLine.appendChild(promptLabel);
    inputLine.appendChild(cmdInput);
    terminal.appendChild(inputLine);
    document.body.appendChild(terminal);

    const printLog = (text, color = "#00ff00") => {
        const line = document.createElement('div');
        line.style.color = color;
        line.textContent = text;
        outputLog.appendChild(line);
        outputLog.scrollTop = outputLog.scrollHeight;
    };

    cmdInput.addEventListener('keydown', (e) => {
        if (e.key === 'Enter') {
            const fullInput = cmdInput.value.trim();
            cmdInput.value = '';
            if (!fullInput) return;
            printLog(`Blooket:\\User> ${fullInput}`, "#ffffff");

            const parts = fullInput.split(' ');
            const command = parts[0].toLowerCase();
            const argument = parts[1];

            switch (command) {
                case 'help':
                    printLog('Commands List:', '#00d2d3');
                    printLog('  doubloons [num] - Voyage coins');
                    printLog('  distance [num]  - Voyage meters');
                    printLog('  gold [num]    - Gold Quest');
                    printLog('  toys [num]    - Santa Workshop');
                    printLog('  classic [num] - Classic points');
                    printLog('  close         - Close console');
                    break;
                case 'close':
                    terminal.remove();
                    break;
                case 'doubloons':
                case 'doub':
                    executeStatChange('d', argument, printLog);
                    break;
                case 'distance':
                case 'dist':
                    executeStatChange('m', argument, printLog);
                    break;
                case 'gold':
                    executeStatChange('g', argument, printLog);
                    break;
                case 'toys':
                    executeStatChange('t', argument, printLog);
                    break;
                case 'classic':
                    executeStatChange('p', argument, printLog);
                    break;
                default:
                    printLog(`Command '${command}' not found.`, "#ff4757");
            }
        }
    });
})();
