(function() {
    'use strict';

    // Get internal game variables
    const getReactState = () => {
        const el = document.querySelector("#app > div > div");
        if (!el) return null;
        for (const key in el) {
            if (key.startsWith("__reactInternalInstance$") || key.startsWith("__reactFiber$")) {
                return el[key]?.return?.stateNode;
            }
        }
        return null;
    };

    // Update server data
    const executeStatChange = (key, amount, logOutput) => {
        let stateNode = getReactState();
        if (!stateNode || !stateNode.props || !stateNode.props.firebase) {
            logOutput("Error: Match not started or data not found.", "#ff4757");
            return;
        }
        stateNode.props.firebase.setVal({
            id: stateNode.props.client.hostId,
            path: "c/" + stateNode.props.client.name + "/" + key,
            val: Number(amount)
        });
        logOutput(`Successfully set ${key.toUpperCase()} to ${amount}`, "#2ed573");
    };

    // --- CREATE TERMINAL WINDOW (GUI) ---
    const terminal = document.createElement('div');
    terminal.style = 'position:fixed; bottom:20px; left:20px; z-index:99999; width:450px; height:280px; background:#1e1e1e; border:2px solid #333; border-radius:6px; font-family:monospace; color:#00ff00; padding:10px; box-shadow:0 10px 30px rgba(0,0,0,0.7); display:flex; flex-direction:column;';

    // Terminal Header
    const header = document.createElement('div');
    header.innerHTML = 'Blooket OS [Version 4.0] - Cheat Terminal<br>Type "help" for a list of commands.<br>------------------------------------';
    header.style = 'font-size:12px; margin-bottom:8px; color:#888; line-height:1.4;';
    terminal.appendChild(header);

    // Terminal History Output Log
    const outputLog = document.createElement('div');
    outputLog.style = 'flex:1; overflow-y:auto; font-size:13px; margin-bottom:8px; line-height:1.3; white-space:pre-wrap;';
    terminal.innerHTML += `<div><span style="color:#00ff00;">C:\\Users\\Blooket></span> welcome</div>`;
    terminal.appendChild(outputLog);

    // Terminal Input Line Container
    const inputLine = document.createElement('div');
    inputLine.style = 'display:flex; align-items:center;';
    
    const promptLabel = document.createElement('span');
    promptLabel.innerHTML = 'C:\\Users\\Blooket&gt;&nbsp;';
    promptLabel.style = 'font-weight:bold; font-size:13px;';
    
    const cmdInput = document.createElement('input');
    cmdInput.type = 'text';
    cmdInput.style = 'flex:1; background:transparent; border:none; color:#00ff00; font-family:monospace; font-size:13px; outline:none;';
    
    inputLine.appendChild(promptLabel);
    inputLine.appendChild(cmdInput);
    terminal.appendChild(inputLine);
    document.body.appendChild(terminal);

    // Helper to print text inside the terminal window
    const printLog = (text, color = "#00ff00") => {
        const line = document.createElement('div');
        line.style.color = color;
        line.textContent = text;
        outputLog.appendChild(line);
        outputLog.scrollTop = outputLog.scrollHeight; // Auto scroll to bottom
    };

    // --- COMMAND PARSER ENGINE ---
    cmdInput.addEventListener('keydown', (e) => {
        if (e.key === 'Enter') {
            const fullInput = cmdInput.value.trim();
            cmdInput.value = ''; // Clear line
            
            if (!fullInput) return;
            printLog(`C:\\Users\\Blooket> ${fullInput}`, "#ffffff");

            const parts = fullInput.split(' ');
            const command = parts[0].toLowerCase();
            const argument = parts[1];

            // Command switch definitions
            switch (command) {
                case 'help':
                    printLog('Available Commands:', '#00d2d3');
                    printLog('  gold [num]    - Set Gold Quest gold');
                    printLog('  toys [num]    - Set Santa Workshop toys');
                    printLog('  tpq [num]     - Set Toys Per Question multiplier');
                    printLog('  classic [num] - Set Classic mode points');
                    printLog('  defense [num] - Set Blook Rush defenses');
                    printLog('  team [num]    - Set Blook Rush team score');
                    printLog('  clear         - Clear the screen logs');
                    break;

                case 'clear':
                    outputLog.innerHTML = '';
                    break;

                case 'gold':
                    if (!argument || isNaN(argument)) return printLog('Error: Specify a valid number. Example: gold 500', '#ff4757');
                    executeStatChange('g', argument, printLog);
                    break;

                case 'toys':
                    if (!argument || isNaN(argument)) return printLog('Error: Specify a valid number.', '#ff4757');
                    executeStatChange('t', argument, printLog);
                    break;

                case 'tpq':
                    if (!argument || isNaN(argument)) return printLog('Error: Specify a valid number.', '#ff4757');
                    executeStatChange('tpq', argument, printLog);
                    break;

                case 'classic':
                    if (!argument || isNaN(argument)) return printLog('Error: Specify a valid number.', '#ff4757');
                    executeStatChange('p', argument, printLog);
                    break;

                case 'defense':
                    if (!argument || isNaN(argument)) return printLog('Error: Specify a valid number.', '#ff4757');
                    executeStatChange('d', argument, printLog);
                    break;

                case 'team':
                    if (!argument || isNaN(argument)) return printLog('Error: Specify a valid number.', '#ff4757');
                    executeStatChange('bs', argument, printLog);
                    break;

                default:
                    printLog(`'${command}' is not recognized as an internal or external command.`, "#ff4757");
            }
        }
    });

})();
