// ==UserScript==
// @name         Blooket Host Dashboard - Player Ban Tool
// @namespace    http://tampermonkey.net
// @version      1.0
// @description  Allows the game host to instantly remove and block specific usernames from a live Blooket lobby.
// @match        *://*://*
// @grant        none
// @run-at       document-idle
// ==/UserScript==

(function() {
    'use strict';

    // Array to store usernames that should be blocked from the session
    let bannedPlayers = [];

    // Helper function to extract React application state from the host dashboard
    const getHostReactState = () => {
        const el = document.querySelector("#app > div > div");
        if (!el) return null;
        for (const key in el) {
            if (key.startsWith("__reactInternalInstance$") || key.startsWith("__reactFiber$")) {
                return el[key]?.return?.stateNode;
            }
        }
        return null;
    };

    // Core function to remove a player from the live server data
    const kickPlayerFromServer = (username) => {
        let stateNode = getHostReactState();
        if (!stateNode || !stateNode.props || !stateNode.props.firebase) return;

        let props = stateNode.props;
        
        // Setting the player's client path to null removes them from the room
        props.firebase.setVal({
            id: props.client.hostId,
            path: "c/" + username,
            val: null
        });
    };

    // Auto-Enforcer: Periodically checks the player list and removes blocked names
    setInterval(() => {
        let stateNode = getHostReactState();
        if (!stateNode || !stateNode.props || !stateNode.props.client || !stateNode.props.client.clients) return;

        let activeClients = Object.keys(stateNode.props.client.clients);
        
        activeClients.forEach(username => {
            if (bannedPlayers.includes(username.toLowerCase())) {
                kickPlayerFromServer(username);
            }
        });
    }, 1000); // Checks every 1 second

    // --- UI CREATION ---
    
    // Control Button
    const banMenuBtn = document.createElement('button');
    banMenuBtn.innerHTML = '🚫 Ban System';
    banMenuBtn.style = 'position:fixed; bottom:15px; right:15px; z-index:99999; padding:10px 15px; background:#eb4d4b; color:white; border:none; border-radius:5px; cursor:pointer; font-weight:bold; box-shadow:0px 4px 6px rgba(0,0,0,0.3);';
    document.body.appendChild(banMenuBtn);

    // Interaction Logic
    banMenuBtn.addEventListener('click', () => {
        const action = prompt("Type '1' to Ban a player, or '2' to view current Ban List:");
        
        if (action === "1") {
            const targetUser = prompt("Enter the EXACT username you want to ban:");
            if (targetUser) {
                const standardizedName = targetUser.trim().toLowerCase();
                if (!bannedPlayers.includes(standardizedName)) {
                    bannedPlayers.push(standardizedName);
                }
                kickPlayerFromServer(targetUser.trim());
                alert(`Player "${targetUser}" has been removed and added to the block list.`);
            }
        } else if (action === "2") {
            if (bannedPlayers.length === 0) {
                alert("The ban list is currently empty.");
            } else {
                alert("Currently Banned Usernames:\n" + bannedPlayers.join("\n"));
            }
        } else if (action !== null) {
            alert("Invalid choice! Please choose 1 or 2.");
        }
    });

})();
