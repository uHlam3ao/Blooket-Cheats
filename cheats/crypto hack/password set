(async () => {
    let n = document.createElement('iframe');
    n.style.display = 'none';
    document.body.append(n);
    const newPass = n.contentWindow.prompt("Enter your new password:");
    if (newPass) {
        const getReact = (el) => {
            for (const key in el) {
                if (key.startsWith("__reactInternalInstance$") || key.startsWith("__reactFiber$")) return el[key];
            }
        };
        try {
            let stateNode = getReact(document.querySelector("#app > div > div")).return.stateNode;
            stateNode.setState({ password: newPass });
            n.contentWindow.alert("Password updated!");
        } catch (e) {
            n.contentWindow.alert("Error!");
        }
    }
    n.remove();
    console.clear();
})();
