(() => {
    let n = document.createElement('iframe');
    n.style.display = 'none';
    document.body.append(n);
    
    const streakAmount = n.contentWindow.prompt('Enter Candy Quest Streak amount:');
    
    if (streakAmount && !isNaN(streakAmount)) {
        const getReact = (el) => {
            for (const key in el) {
                if (key.startsWith('__reactInternalInstance$') || key.startsWith('__reactFiber$')) {
                    return el[key];
                }
            }
        };

        try {
            let reactElem = getReact(document.querySelector('#app > div > div'));
            if (reactElem && reactElem.return && reactElem.return.stateNode) {
                let stateNode = reactElem.return.stateNode;
                
                // Updates the win streak count in the game engine state
                stateNode.setState({ 
                    streak: Number(streakAmount)
                });
                
                n.contentWindow.alert(`Streak set to ${streakAmount}!`);
            } else {
                n.contentWindow.alert('Game instance not found!');
            }
        } catch (e) {
            n.contentWindow.alert('Error updating streak!');
        }
    }
    
    n.remove();
    console.clear();
})();
