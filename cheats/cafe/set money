(async () => {
    let n = document.createElement("iframe");
    n.style.display = "none";
    document.body.append(n);
    
    const cashAmount = n.contentWindow.prompt("Enter Cash Amount:");
    
    if (cashAmount) {
        const getReact = (el) => {
            for (const key in el) {
                if (key.startsWith("__reactInternalInstance$") || key.startsWith("__reactFiber$")) 
                    return el[key];
            }
        };

        try {
                   let stateNode = getReact(document.querySelector("#app > div > div")).return.stateNode;
            
            stateNode.setState({ cash: Number(cashAmount) });
            
            n.contentWindow.alert("Cash set to " + cashAmount + "!");
        } catch (e) {
            n.contentWindow.alert("Error: Make sure you are on the Café game screen.");
        }
    }
    
    n.remove();
    console.clear();
})();
