(async () => {
    // 1. Prompts the user to confirm they want to attempt claiming rewards
    let n = document.createElement('iframe');
    n.style.display = 'none';
    document.body.append(n);
    
    if (!n.contentWindow.confirm('Claim Daily Reward, Tokens, and XP?')) {
        n.remove();
        return;
    }

    const getReact = (el) => {
        for (const key in el) {
            if (key.startsWith('__reactInternalInstance$') || key.startsWith('__reactFiber$')) {
                return el[key];
            }
        }
    };

    try {
        // 2. Intercepts the React state payload on the dashboard
        let reactElem = getReact(document.querySelector('#app > div > div'));
        if (reactElem && reactElem.return && reactElem.return.stateNode) {
            let stateNode = reactElem.return.stateNode;
            
            // Simulates local state changes for daily collections
            stateNode.setState({
                tokens: Math.min((stateNode.state.tokens || 0) + 500, 1000),
                xp: Math.min((stateNode.state.xp || 0) + 300, 300),
                dailyRewardClaimed: true
            });
            
            n.contentWindow.alert('Daily dashboard payload update requested!');
        } else {
            // 3. Fallback: attempts a simulated direct fetch request to the reward endpoint
            const token = localStorage.getItem('token') || document.cookie;
            if (token) {
                await fetch('https://blooket.com', {
                    method: 'PUT',
                    headers: { 'Content-Type': 'application/json' }
                });
                n.contentWindow.alert('Daily Bonus endpoint pinged successfully!');
            } else {
                n.contentWindow.alert('Could not find active session credentials. Make sure you are logged in on the Dashboard page!');
            }
        }
    } catch (e) {
        n.contentWindow.alert('Error executing daily reward request!');
    }

    n.remove();
    console.clear();
})();
