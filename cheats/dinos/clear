(() => {
    // 1. Clears other common cheat scripts, auto-clickers, and custom global variables
    const commonLoops = [
        'fossilMultiplierLoop', 'bestChoiceLoop', 'bestOptionLoop', 
        'cheatLoop', 'hackLoop', 'autoSolver', 'autoClicker', 
        'blooketCheat', 'gimkitCheat', 'kahootCheat'
    ];

    commonLoops.forEach(loopName => {
        if (window[loopName]) {
            clearInterval(window[loopName]);
            delete window[loopName];
        }
    });

    // 2. Scans and destroys all generic active background intervals on the page
    let highestTimeoutId = setTimeout(() => {}, 0);
    for (let i = 0; i <= highestTimeoutId; i++) {
        clearInterval(i);
        clearTimeout(i);
    }

    // 3. Alerts you that the cleanup is done
    let n = document.createElement('iframe');
    n.style.display = 'none';
    document.body.append(n);
    n.contentWindow.alert('All active hacks cleared!');
    n.remove();
    console.clear();
})();
