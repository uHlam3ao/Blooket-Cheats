(async () => {
    let n = document.createElement('iframe');
    n.style.display = 'none';
    document.body.append(n);
    
    const amount = n.contentWindow.prompt("Enter the total Classic Points you want:");
    
    if (amount) {
        const getReact = (el) => {
            for (const key in el) {
                if (key.startsWith("__reactInternalInstance$") || key.startsWith("__reactFiber$")) return el[key];
            }
        };
        try {
            // Locate the stateNode of the React application
            let stateNode = getReact(document.querySelector("#app > div > div")).return.stateNode;
            let props = stateNode.props;
            
            // 'p' stands for Points in Classic mode
            props.firebase.setVal({
                id: props.client.hostId,
                path: "c/" + props.client.name + "/p",
                val: Number(amount)
            });
            
            n.contentWindow.alert("Classic points updated successfully!");
        } catch (e) {
            n.contentWindow.alert("Error! Make sure you are actively playing a Classic match.");
        }
    }
    
    n.remove();
    console.clear();
})();
