(async () => {
    let n = document.createElement('iframe');
    n.style.display = 'none';
    document.body.append(n);
    
    const amount = n.contentWindow.prompt("Enter the total Gold you want:");
    
    if (amount) {
        const getReact = (el) => {
            for (const key in el) {
                if (key.startsWith("__reactInternalInstance$") || key.startsWith("__reactFiber$")) return el[key];
            }
        };
        try {
            // Locate the stateNode of the live game
            let stateNode = getReact(document.querySelector("#app > div > div")).return.stateNode;
            let props = stateNode.props;
            
            // 'g' is the server database key that tracks Gold quantities
            props.firebase.setVal({
                id: props.client.hostId,
                path: "c/" + props.client.name + "/g",
                val: Number(amount)
            });
            
            n.contentWindow.alert("Gold updated successfully!");
        } catch (e) {
            n.contentWindow.alert("Error! Make sure you are inside an active Gold Quest match.");
        }
    }
    
    n.remove();
    console.clear();
})();
