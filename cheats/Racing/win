(async () => {
    let n = document.createElement("iframe");
    n.style.display = "none";
    document.body.append(n);

    const getReact = (el) => {
        for (const key in el) {
            if (key.startsWith("__reactInternalInstance$") || key.startsWith("__reactFiber$")) 
                return el[key];
        }
    };

    try {
        let stateNode = getReact(document.querySelector("#app > div > div")).return.stateNode;
        let targetGoal = stateNode.state.goalAmount || 100; 
        
        stateNode.setState({ progress: targetGoal });

        if (typeof stateNode.handleCorrect === "function") {
            stateNode.handleCorrect();
        } else if (typeof stateNode.submitAnswer === "function") {
            stateNode.submitAnswer(true);
        } else if (typeof stateNode.movePlayer === "function") {
            stateNode.movePlayer(targetGoal);
        }
        
        n.contentWindow.alert("Instant win triggered!");
    } catch (e) {
        n.contentWindow.alert("Error!");
    }
    
    n.remove();
    console.clear();
})();
