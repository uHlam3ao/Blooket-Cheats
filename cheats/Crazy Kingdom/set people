(() => {
    let n = document.createElement('iframe');
    n.style.display = 'none';
    document.body.append(n);
    
    const peopleAmount = n.contentWindow.prompt('Enter Crazy Kingdom People amount (0-100):');
    
    if (peopleAmount && !isNaN(peopleAmount)) {
        const getReact = (el) => {
            for (const key in el) {
                if (key.startsWith('__reactInternalInstance$') || key.startsWith('__reactFiber$')) {
                    return el[key];
                }
            }
        };

        try {
            let reactElem = getReact(document.querySelector('#app > div > div'));
            if (reactElem && reactElem.return && reactElem.return.stateNode) {
                let stateNode = reactElem.return.stateNode;
                
                stateNode.setState({ 
                    people: Number(peopleAmount)
                });
                
                n.contentWindow.alert(`People set to ${peopleAmount}!`);
            } else {
                n.contentWindow.alert('Game instance not found!');
            }
        } catch (e) {
            n.contentWindow.alert('Error updating people!');
        }
    }
    
    n.remove();
    console.clear();
})();
